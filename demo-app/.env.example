# Dynatrace OTLP log ingest — classic endpoint, NOT the platform gateway: the
# platform OTLP path (.apps.dynatrace.com/platform/...) only accepts Bearer
# auth, while Api-Token auth requires the classic API v2 path (verified live,
# see TENANT_SETUP.md step 1).
DT_OTLP_ENDPOINT=https://egc32068.live.dynatrace.com/api/v2/otlp/v1/logs
# Ingest-scoped API token (logs.ingest + events.ingest). NOT the MCP server's DT_PLATFORM_TOKEN.
DT_API_TOKEN=dt0c01.REPLACE_ME
# Classic events API for deployment markers (verify in TENANT_SETUP.md step 2; optional —
# scripts warn and continue without it)
DT_EVENTS_ENDPOINT=https://egc32068.live.dynatrace.com/api/v2/events/ingest
PORT=3000
